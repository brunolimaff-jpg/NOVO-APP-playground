{
  "compilerOptions": {
    "target": "ES2022",
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "module": "ESNext",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "skipLibCheck": true,
    "types": [
      "node",
      "vite/client"
    ],
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "moduleDetection": "force",
    "allowJs": true,
    "jsx": "react-jsx",
    "paths": {
      "@/*": [
        "./*"
      ]
    },
    "allowImportingTsExtensions": true,
    "noEmit": true,
    // Strict gradual — fase 1: bloqueia `any` implícito e null não verificado
    // Para novos arquivos: toda declaração precisa de tipo explícito.
    // Arquivos legados com erros: adicione `// @ts-expect-error` pontualmente.
    "noImplicitAny": true,
    "strictNullChecks": true
  }
}