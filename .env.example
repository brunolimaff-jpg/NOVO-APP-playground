# === Required ===
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_key_here
GEMINI_API_KEY=your_gemini_api_key_here
PINECONE_API_KEY=your_pinecone_api_key_here

# === Optional ===
# Pinecone docs-specific key and index (falls back to PINECONE_API_KEY)
PINECONE_DOCS_KEY=
PINECONE_DOCS_INDEX=scout-arsenal

# Backend URLs (defaults to Google Apps Script endpoints)
VITE_BACKEND_URL=
VITE_LOOKUP_URL=

# Model overrides (defaults shown)
VITE_ROUTER_MODEL=gemini-2.5-flash
VITE_TACTICAL_MODEL=gemini-2.5-flash
VITE_DEEP_CHAT_MODEL=gemini-3.1-pro-preview
VITE_DEEP_RESEARCH_MODEL=gemini-3.1-pro-preview
